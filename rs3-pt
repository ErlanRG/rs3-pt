#!/usr/bin/env bash

WORLDS="1 10 100 101 102 103 104 105 106 114 115 116 117 118 119 12 121 123 124 134 137 138 139 14 140 15 16 18 2 21 22 23 24 25 252 257 258 259 26 27 28 30 31 32 35 36 37 39 4 40 42 44 45 46 47 48 49 5 50 51 52 53 54 56 58 59 6 60 62 63 64 65 66 67 68 69 70 71 72 73 74 75 76 77 78 79 82 83 84 85 86 87 88 89 9 91 92 96 97 98 99"

echo "$WORLDS" | tr ' ' '\n' | xargs -I{} -P 20 bash -c '
HOST="world{}.runescape.com"
PING_RESULT=$(ping -c 1 -W 1 $HOST 2>/dev/null)
LATENCY=$(echo "$PING_RESULT" | grep -o "time=[0-9.]*" | cut -d= -f2)

if [[ -n "$LATENCY" ]]; then
    echo "$LATENCY world{}.runescape.com"
fi
' | sort -n | head -n 3
